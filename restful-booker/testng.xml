<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite" parallel="classes" thread-count="5" data-provider-thread-count="3">
    <listeners>
        <listener class-name="com.prasad_v.retry.RetryListener"/>
        <listener class-name="com.prasad_v.listeners.TestExecutionListener"/>
    </listeners>

    <!-- Independent CRUD tests -->
    <test verbose="2" preserve-order="true" name="CRUD Tests">
        <classes>
            <class name="com.prasad_v.tests.crud.TestCreateBooking">
                <methods><include name="testCreateBookingPOST"/></methods>
            </class>
            <class name="com.prasad_v.tests.crud.TestCreateToken">
                <methods><include name="testTokenPOST"/></methods>
            </class>
            <class name="com.prasad_v.tests.crud.TestHealthCheck">
                <methods><include name="testGETHealthCheck"/></methods>
            </class>
        </classes>
    </test>

    <!-- Assignment tests -->
    <test verbose="2" preserve-order="true" name="Assignment Tests">
        <classes>
            <class name="com.prasad_v.tests.integration.E2ETest_Assignment1">
                <methods><include name="testCreateDeleteVerifyBooking"/></methods>
            </class>
            <class name="com.prasad_v.tests.integration.E2ETest_Assignment2">
                <methods><include name="testGetAndTryToDeleteBooking"/></methods>
            </class>
            <class name="com.prasad_v.tests.integration.E2ETest_Assignment3">
                <methods><include name="testCreateUpdateDeleteBooking"/></methods>
            </class>
            <class name="com.prasad_v.tests.integration.E2ETest_Assignment4">
                <methods><include name="testDeleteThenTryToUpdateBooking"/></methods>
            </class>
        </classes>
    </test>

    <!-- Sample stub tests -->
    <test verbose="2" preserve-order="true" name="Sample Tests">
        <classes>
            <class name="com.prasad_v.tests.sample.TestIntegrationSample">
                <methods>
                    <include name="testCreateBooking"/>
                    <include name="testVerifyBookingId"/>
                    <include name="testUpdateBookingByID"/>
                    <include name="testDeleteBookingById"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- E2E flows run sequentially -->
    <test verbose="2" preserve-order="true" name="E2E Flow 01" parallel="false">
        <classes>
            <class name="com.prasad_v.tests.integration.TestE2EFlow_01">
                <methods>
                    <include name="testCreateBooking"/>
                    <include name="testVerifyBookingId"/>
                    <include name="testUpdateBookingByID"/>
                    <include name="testDeleteBookingById"/>
                </methods>
            </class>
        </classes>
    </test>

    <test verbose="2" preserve-order="true" name="E2E Flow 02" parallel="false">
        <classes>
            <class name="com.prasad_v.tests.integration.TestE2EFlow_02">
                <methods>
                    <include name="createBooking"/>
                    <include name="verifyBooking"/>
                    <include name="deleteBooking"/>
                    <include name="verifyBookingDeleted"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
